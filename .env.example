# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_user_id_here

# Cron設定 (デフォルト: 毎日8:00 JST)
# Railway/Renderでは内部cronを使用するためこの値を使用
CRON_SCHEDULE=0 23 * * *
# ↑ UTC 23:00 = JST 08:00 (翌日)
# 注意: サーバーのタイムゾーンがUTCの場合はこの設定を使用
# TZ=Asia/Tokyo を設定する場合は 0 8 * * * に変更

# タイムゾーン (デプロイ先で設定)
TZ=Asia/Tokyo
